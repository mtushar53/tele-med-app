# Agora Configuration Example
# Copy this file to .env and update with your actual values

# Agora App ID
AGORA_APP_ID=your_agora_app_id_here

# Agora Token (temporary token for testing purposes)
AGORA_TOKEN=your_agora_token_here

# Default channel name for testing
AGORA_DEFAULT_CHANNEL_NAME=your_channel_name_here
